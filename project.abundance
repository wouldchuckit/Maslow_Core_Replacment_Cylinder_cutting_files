        {
          "atomType": "Readme",
          "x": 0.8145833333333333,
          "y": 0.3647342995169082,
          "uniqueID": "id-260194",
          "name": "README",
          "ioValues": [
            {
              "name": "value",
              "ioValue": "__GEOMETRY_INPUT__"
            }
          ],
          "readMeText": "This piece is the template for cutting the two rubber sheets. It will not be in the final assembly. ",
          "global": true
        },
        {
          "atomType": "Readme",
          "x": 0.8213541666666667,
          "y": 0.12318840579710146,
          "uniqueID": "id-260195",
          "name": "README",
          "ioValues": [
            {
              "name": "value",
              "ioValue": "__GEOMETRY_INPUT__"
            }
          ],
          "readMeText": "This is a pen holder that would replace the bottom two layers of the wooden router core replacement cylinder. Two pieces of rubber sheet (inner tube) can be cut to the dimensions of the top disk (which is not in the final assembly and then clamped between the thin circles and the main body of the pen holder. Pen or pencil can be inserted in the two middle holes in the rubber. ",
          "global": true
        },
        {
          "atomType": "Readme",
          "x": 0.029166666666666667,
          "y": 0.48309178743961356,
          "uniqueID": "id-260196",
          "name": "README",
          "ioValues": [
            {
              "name": "value",
              "ioValue": "__GEOMETRY_INPUT__"
            }
          ],
          "readMeText": "The input values should match the values in the Maslow4 Router core replacement molecule referenced in this model. ",
          "global": true
        },
        {
          "atomType": "Readme",
          "x": 0.734375,
          "y": 0.8695652173913044,
          "uniqueID": "id-260197",
          "name": "README",
          "ioValues": [
            {
              "name": "value",
              "ioValue": "__GEOMETRY_INPUT__"
            }
          ],
          "readMeText": "In it's current form this would need 6 1/8 in bolts and nuts at least 2.5 inches long. ",
          "global": true
        },
