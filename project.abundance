          ]
        },
        {
          "atomType": "Code",
          "x": 0.45833333333333337,
          "y": 0.33704735376044564,
          "uniqueID": "id-261680",
          "ioValues": [
            {
              "name": "input",
              "ioValue": "__GEOMETRY_INPUT__"
            },
            {
              "name": "labelColor",
              "ioValue": "#3A2F28",
              "currentEquation": "#3A2F28"
            },
            {
              "name": "fontSize",
              "ioValue": 34
